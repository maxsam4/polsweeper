# Private key for the gas account that pays for deploy + sweep transactions
GAS_PRIVATE_KEY=0xYOUR_PRIVATE_KEY_HERE

# Sequence indexer API key (get from sequence.build)
SEQUENCE_API_KEY=your_sequence_api_key_here

# Polygon PoS mainnet RPC URL
RPC_URL=https://polygon-rpc.com

# Deployed VirtualAccountCreator factory contract address
FACTORY_ADDRESS=0xYOUR_FACTORY_ADDRESS_HERE

# Auth token for basic API authentication
AUTH_TOKEN=your_secret_auth_token_here

# Server port (optional, defaults to 3001)
PORT=3001
